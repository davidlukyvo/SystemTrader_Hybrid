[Unit]
Description=Run SystemTrader Hybrid scanner runner on a fixed schedule

[Timer]
OnCalendar=*-*-* 00:00:00
OnCalendar=*-*-* 06:00:00
OnCalendar=*-*-* 07:00:00
OnCalendar=*-*-* 08:00:00
OnCalendar=*-*-* 09:00:00
OnCalendar=*-*-* 10:30:00
OnCalendar=*-*-* 14:30:00
OnCalendar=*-*-* 17:00:00
OnCalendar=*-*-* 21:00:00
OnCalendar=*-*-* 23:00:00
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
