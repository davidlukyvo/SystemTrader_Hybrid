[Unit]
Description=SystemTrader Hybrid sanitized IndexedDB backup export
After=systemtrader-browser.service

[Service]
Type=oneshot
User=systemtrader
Group=systemtrader
EnvironmentFile=/etc/systemtrader/systemtrader.env
WorkingDirectory=/opt/systemtrader
ExecStart=/usr/bin/node /opt/systemtrader/ops/export-backup.js
